# hAI.PeeDHCP – Umgebungsvariablen
# Kopieren: cp .env.example .env  dann anpassen

# === PiHole v6 API ===
# URL zu PiHole (vom Container aus erreichbar)
# Meistens die Host-IP oder der Containername
PIHOLE_URL=http://192.168.1.1       # <-- IP des PiHole-Hosts anpassen

# API-Key aus PiHole Web-UI: Settings → API → Show API token
PIHOLE_API_KEY=dein-pihole-api-key-hier

# === Backend ===
LOG_LEVEL=INFO
TZ=Europe/Berlin
