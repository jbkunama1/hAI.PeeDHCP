# hAI.PeeDHCP – Umgebungsvariablen
# Kopieren: cp .env.example .env  dann anpassen

# === PiHole v6 ===
# URL zu PiHole (vom Container aus erreichbar, meist Host-IP)
PIHOLE_URL=http://192.168.178.1

# PiHole Web-Passwort (wird nur zum Einloggen verwendet, Session wird gecacht)
PIHOLE_PASSWORD=dein-pihole-passwort

# === Backend ===
LOG_LEVEL=INFO
TZ=Europe/Berlin
