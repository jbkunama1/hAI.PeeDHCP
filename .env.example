# hAI.PeeDHCP – Umgebungsvariablen
# Kopieren: cp .env.example .env  dann anpassen

# === Sicherheit ===
SECRET_KEY=changeme-bitte-aendern          # Zufallsstring, min. 32 Zeichen

# === PiHole Dateipfade ===
PIHOLE_LEASES=/var/lib/misc/dnsmasq.leases
PIHOLE_STATIC_CONF=/etc/dnsmasq.d/04-pihole-static-dhcp.conf
PIHOLE_SETUPVARS=/etc/pihole/setupVars.conf
PIHOLE_DNSMASQ_DHCP=/etc/dnsmasq.d/02-pihole-dhcp.conf
PIHOLE_LOG=/var/log/pihole.log

# === Backend ===
FLASK_ENV=production
LOG_LEVEL=INFO
TZ=Europe/Berlin
